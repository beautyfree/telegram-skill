{
  "name": "telegram-agent",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:daemon": "bun --filter @tg/daemon dev",
    "cli": "bun run apps/cli/src/index.ts --",
    "build": "bun --filter './packages/*' build && bun --filter './apps/*' build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun --filter '*' test",
    "test:e2e": "bun --filter '*' test:e2e",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "apcach": "^0.6.4",
    "typescript": "^5.7.2"
  },
  "version": "2.0.0-beta.1",
  "description": "Telegram CLI for AI agents — TDLib-powered fork of avemeva/kurier with reaction-tags, session export, and skill bundle.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beautyfree/telegram-agent.git"
  },
  "author": "Alexey Elizarov <alex.elizarov1@gmail.com>",
  "bugs": {
    "url": "https://github.com/beautyfree/telegram-agent/issues"
  },
  "homepage": "https://github.com/beautyfree/telegram-agent#readme"
}
