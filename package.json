{
  "name": "telegram-agent",
  "version": "1.0.10",
  "description": "Telegram agent-skill for Claude Code, Codex CLI, Cursor, Gemini CLI, Cline, Windsurf, and any AI coding agent that supports the universal SKILL.md format. Lazy-loaded — ~0 context tokens until your prompt mentions Telegram. Standalone CLI (`telegram-agent`) talks to Telegram MTProto directly via gram.js. JSON-first output. One-command install for every major agent client. Read dialogs, search globally, send/edit/forward/react, tag Saved Messages (Premium reaction-tags), moderate channels, transcribe voice notes.",
  "type": "module",
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "author": "Alexey Elizarov <alex.elizarov1@gmail.com>",
  "license": "MIT",
